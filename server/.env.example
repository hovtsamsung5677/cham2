# Пример переменных окружения для AI-сервера.
# Скопируйте в server/.env и настройте под ваше окружение.
# Значения читаются в app.py через os.getenv(...).

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
# В продакшене рекомендуется WARNING, чтобы не логировать имена файлов,
# координаты и параметры запросов.
LOG_LEVEL=WARNING

# Разрешённые источники для CORS (через запятую).
# Оставьте пустым, если к серверу обращается только нативное приложение
# (мобильным клиентам CORS не нужен).
# Пример: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# API-ключи для доступа к серверу (через запятую).
# Клиент должен передавать один из них в заголовке X-API-Key.
# Если пусто — проверка ключа ОТКЛЮЧЕНА (только для локальной отладки!).
# Сгенерировать ключ: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=

# Количество воркеров (процессов) Uvicorn. Каждый воркер самостоятельно
# загружает модели, поэтому запросы обрабатываются параллельно.
# Рекомендуется не больше числа доступных GPU/ядер CPU. По умолчанию 2.
WEB_CONCURRENCY=2

# Максимальное число одновременных GPU-задач (инференс SAM-2 + FLUX) внутри
# одного воркера. Защищает модели от конкурентного доступа и предотвращает
# CUDA OOM. Остальные запросы параллельно ждут в очереди. По умолчанию 2.
MAX_CONCURRENT_JOBS=2
